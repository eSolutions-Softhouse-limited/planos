#!/usr/bin/env node
// Coexistence-spike stub bin for plannotator-stub-a.
//
// Purpose: when installed ALONGSIDE planos (./plugin), this records that ITS
// EnterPlanMode / ExitPlanMode hook fired (to a marker file) and emits a
// benign hook output. Comparing markers + planos behavior reveals whether
// Claude Code dispatches the same hook event to ALL matching plugins, one,
// or errors. Not shipped — tests/spike only.

import { appendFileSync } from 'node:fs';

const sub = process.argv[2] || '?';
const marker =
  process.env.PLANOS_SPIKE_MARKER || '/tmp/planos-coexistence-marker.log';

let stdin = '';
try {
  stdin = require('node:fs').readFileSync(0, 'utf8');
} catch {
  /* no stdin */
}

try {
  appendFileSync(
    marker,
    JSON.stringify({
      plugin: 'plannotator-stub-a',
      sub,
      ts: new Date().toISOString(),
      stdinBytes: stdin.length,
    }) + '\n',
  );
} catch {
  /* best-effort marker */
}

if (sub === 'enter') {
  process.stdout.write(
    JSON.stringify({
      hookSpecificOutput: {
        hookEventName: 'PreToolUse',
        additionalContext: '[plannotator-stub-a: EnterPlanMode hook fired]',
      },
    }) + '\n',
  );
  process.exit(0);
}

if (sub === 'exit') {
  // Benign allow so the spike never deadlocks a session on the stub.
  process.stdout.write(
    JSON.stringify({
      hookSpecificOutput: {
        hookEventName: 'PermissionRequest',
        decision: { behavior: 'allow' },
      },
    }) + '\n',
  );
  process.exit(0);
}

if (sub === 'prompt') {
  // UserPromptSubmit fires in non-interactive `claude -p` — this is the
  // headlessly-triggerable event used to empirically corroborate the
  // documented "all matching plugins' hooks fire" dispatch policy. Emit no
  // additionalContext (exit 0) so it cannot perturb the agent.
  process.exit(0);
}

process.stdout.write('[plannotator-stub-a: unknown subcommand ' + sub + ']\n');
process.exit(0);
