function activeIdStrategy(env = process.env) {
  const strategy = getStrategy(env);
  return {
    strategy,
    idFactory: makeIdFactory(strategy),
    authoringInstruction: idPreservationInstruction(strategy)
  };
}
var init_schema = __esm({
  "src/schema/index.mjs"() {
    "use strict";
